{
  "description": "Always-on house rules (SessionStart) + Bash anti-pattern enforcement (PreToolUse).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ${CLAUDE_PLUGIN_ROOT}/rules/house-rules.md"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/bash-anti-patterns.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
